---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
// Header は専用ナビを使うため読み込みません。

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props as any;
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description ?? ''} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+JP:wght@400;500;700;900&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- ============ NAV ============ -->
		<nav class="fd-nav">
			<div class="fd-brand"><span class="fd-dot"></span>FAIRWAY DIARY</div>
			<ul>
				<li><a href="/">HOME</a></li>
				<li><a href="/blog">REPORT</a></li>
				<li><a href="/about">ABOUT</a></li>
				<li><a href="/contact">CONTACT</a></li>
			</ul>
			<a href="/" class="fd-cta">SUBSCRIBE</a>
		</nav>

		<!-- ============ POST HERO ============ -->
		<header class="fd-postHero">
			<div class="fd-heroLayer1" aria-hidden="true"></div>
			<div class="fd-heroLayer2" aria-hidden="true"></div>
			<div class="fd-heroBall" aria-hidden="true"></div>
			<div class="fd-heroScan" aria-hidden="true"></div>

			<div class="fd-postHeroInner">
				<a href="/blog" class="fd-back">← REPORTS</a>
				<span class="fd-badge"><span class="live"></span>ON-SITE REPORT</span>
				<h1 class="fd-postTitle">{title}</h1>
				{description && <p class="fd-postDesc">{description}</p>}
				<div class="fd-postMeta">
					<span class="fd-postDate"><FormattedDate date={pubDate} /></span>
					{updatedDate && (
						<span class="fd-postUpdated">UPDATED <FormattedDate date={updatedDate} /></span>
					)}
					{tags && tags.length > 0 && (
						<span class="fd-postTags">
							{tags.map((t: string) => <span class="fd-tagPill">#{t}</span>)}
						</span>
					)}
				</div>
			</div>
		</header>

		<!-- ============ MARQUEE ============ -->
		<div class="fd-marquee" aria-hidden="true">
			<div class="fd-marqueeInner">
				<span>NOW READING — {title}<span class="star"></span>FAIRWAY DIARY<span class="star"></span>JLPGA 2026<span class="star"></span></span>
				<span>NOW READING — {title}<span class="star"></span>FAIRWAY DIARY<span class="star"></span>JLPGA 2026<span class="star"></span></span>
			</div>
		</div>

		<!-- ============ ARTICLE BODY ============ -->
		<main class="fd-article">
			<div class="fd-articleInner">
				{heroImage && (
					<figure class="fd-hero-image">
						<img src={typeof heroImage === 'string' ? heroImage : heroImage.src} alt="" />
					</figure>
				)}
				<article class="fd-prose">
					<slot />
				</article>

				<!-- 記事末の戻る導線 -->
				<div class="fd-postNav">
					<a href="/blog" class="fd-btn-outline">← 一覧に戻る</a>
					<a href="/" class="fd-btn">HOME →</a>
				</div>
			</div>
		</main>

		<!-- ============ FOOTER (共通部品) ============ -->
		<Footer />

		<style is:global>
			:root{
				--green-900:#0b3d1f; --green-700:#11733a; --green-500:#1fb35a;
				--green-300:#7ce0a1; --lime:#c8ff3c; --ink:#0d1411;
				--paper:#f6fbf6; --line:rgba(13,20,17,.08);
			}
			html,body{margin:0;padding:0;background:var(--paper);color:var(--ink);font-family:"Noto Sans JP",system-ui,sans-serif;-webkit-font-smoothing:antialiased;overflow-x:hidden}
			a{color:inherit;text-decoration:none}
			img{max-width:100%;display:block}

			/* NAV */
			.fd-nav{position:fixed;inset:0 0 auto 0;z-index:50;display:flex;align-items:center;justify-content:space-between;padding:18px 32px;background:linear-gradient(180deg,rgba(0,0,0,.55),rgba(0,0,0,0));color:#fff}
			.fd-brand{display:flex;align-items:center;gap:10px;font-family:"Bebas Neue",sans-serif;font-size:24px;letter-spacing:.12em}
			.fd-brand .fd-dot{width:10px;height:10px;border-radius:50%;background:var(--lime);box-shadow:0 0 0 4px rgba(200,255,60,.25);animation:fd-pulse 1.6s infinite}
			.fd-nav ul{display:flex;gap:28px;list-style:none;font-size:13px;letter-spacing:.18em;margin:0;padding:0}
			.fd-nav ul a{opacity:.85;transition:opacity .2s}
			.fd-nav ul a:hover{opacity:1}
			.fd-cta{background:var(--lime);color:var(--ink);padding:10px 18px;border-radius:999px;font-weight:700;font-size:12px;letter-spacing:.15em}
			@media (max-width:760px){.fd-nav ul{display:none}}

			/* POST HERO */
			.fd-postHero{position:relative;min-height:50vh;padding:120px 0 60px;overflow:hidden;color:#fff;background:#06140b;display:flex;align-items:center}
			.fd-heroLayer1{position:absolute;inset:0;z-index:0;background:radial-gradient(900px 600px at 30% 30%, #11733a 0%, transparent 60%),radial-gradient(800px 500px at 75% 70%, #1fb35a 0%, transparent 60%),linear-gradient(160deg,#04120a 0%, #0b3d1f 60%, #11733a 100%);animation:fd-breath 8s ease-in-out infinite alternate}
			@keyframes fd-breath{0%{filter:brightness(.85) saturate(1)}100%{filter:brightness(1.15) saturate(1.3)}}
			.fd-heroLayer2{position:absolute;inset:-30%;z-index:1;pointer-events:none;background:repeating-linear-gradient(115deg,transparent 0 80px,rgba(200,255,60,.05) 80px 82px,transparent 82px 200px,rgba(124,224,161,.08) 200px 204px,transparent 204px 380px,rgba(255,255,255,.06) 380px 382px,transparent 382px 520px);animation:fd-slide 9s linear infinite}
			@keyframes fd-slide{0%{transform:translateX(-15%) translateY(-5%)}100%{transform:translateX(15%) translateY(5%)}}
			.fd-heroBall{position:absolute;width:14px;height:14px;border-radius:50%;background:radial-gradient(circle at 30% 30%, #fff, #cdd 70%, #889 100%);box-shadow:0 0 18px rgba(255,255,255,.7),0 0 6px rgba(200,255,60,.6);z-index:2;left:-30px;bottom:25%;animation:fd-ball 7s cubic-bezier(.4,0,.7,1) infinite}
			.fd-heroBall::after{content:"";position:absolute;left:-180px;top:50%;width:200px;height:2px;background:linear-gradient(90deg,transparent,rgba(200,255,60,.7) 70%,#fff);transform:translateY(-50%);filter:blur(1px);border-radius:2px}
			@keyframes fd-ball{0%{left:-30px;bottom:18%;transform:scale(.6)}50%{bottom:78%;transform:scale(1.1)}100%{left:110%;bottom:55%;transform:scale(.4)}}
			.fd-heroScan{position:absolute;inset:0;z-index:2;pointer-events:none;opacity:.15;background:repeating-linear-gradient(180deg, rgba(255,255,255,.6) 0 1px, transparent 1px 4px);animation:fd-scan 6s linear infinite}
			@keyframes fd-scan{0%{background-position:0 0}100%{background-position:0 8px}}
			@keyframes fd-pulse{50%{transform:scale(1.4);opacity:.6}}

			.fd-postHeroInner{position:relative;z-index:3;max-width:920px;width:100%;margin:0 auto;padding:0 32px;animation:fd-fadeUp .9s ease both}
			@keyframes fd-fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
			.fd-back{display:inline-flex;align-items:center;font-family:"Bebas Neue",sans-serif;letter-spacing:.25em;font-size:13px;color:#fff;opacity:.7;margin-bottom:18px;transition:opacity .2s}
			.fd-back:hover{opacity:1}
			.fd-badge{display:inline-flex;align-items:center;gap:8px;padding:8px 14px;border:1px solid rgba(255,255,255,.4);border-radius:999px;font-size:11px;letter-spacing:.25em;backdrop-filter:blur(6px);background:rgba(0,0,0,.25);color:#fff}
			.fd-badge .live{width:8px;height:8px;border-radius:50%;background:#ff3b3b;box-shadow:0 0 0 4px rgba(255,59,59,.25);animation:fd-pulse 1.6s infinite}
			.fd-postTitle{font-size:clamp(28px,5vw,56px);font-weight:900;line-height:1.25;margin:18px 0 12px;color:#fff;text-shadow:0 4px 30px rgba(0,0,0,.5)}
			.fd-postDesc{max-width:720px;font-size:15px;line-height:1.9;color:rgba(255,255,255,.8);margin:0 0 24px}
			.fd-postMeta{display:flex;flex-wrap:wrap;gap:16px;align-items:center;font-size:12px;letter-spacing:.15em;color:rgba(255,255,255,.85);padding-top:18px;border-top:1px solid rgba(255,255,255,.18)}
			.fd-postDate{font-family:"Bebas Neue",sans-serif;font-size:14px;color:var(--lime);letter-spacing:.2em}
			.fd-postUpdated{font-family:"Bebas Neue",sans-serif;font-size:12px;opacity:.7}
			.fd-postTags{display:flex;flex-wrap:wrap;gap:8px}
			.fd-tagPill{display:inline-block;background:rgba(200,255,60,.15);color:var(--lime);padding:4px 10px;border-radius:999px;font-size:11px;letter-spacing:.1em}

			/* MARQUEE */
			.fd-marquee{background:var(--lime);color:var(--ink);overflow:hidden;border-top:2px solid var(--ink);border-bottom:2px solid var(--ink);padding:12px 0}
			.fd-marqueeInner{display:flex;gap:48px;white-space:nowrap;font-family:"Bebas Neue",sans-serif;font-size:18px;letter-spacing:.18em;animation:fd-marquee 36s linear infinite}
			.fd-marqueeInner span{display:inline-flex;align-items:center;gap:48px}
			.fd-marqueeInner .star{display:inline-block;width:6px;height:6px;background:var(--ink);border-radius:50%}
			@keyframes fd-marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

			/* ARTICLE */
			.fd-article{background:var(--paper);position:relative;padding:80px 24px 120px}
			.fd-article::before{
				content:"";position:absolute;inset:0;pointer-events:none;opacity:.4;
				background:radial-gradient(800px 500px at 90% 10%, rgba(31,179,90,.08), transparent 60%),
					radial-gradient(700px 500px at 5% 90%, rgba(200,255,60,.06), transparent 60%);
			}
			.fd-articleInner{position:relative;max-width:760px;margin:0 auto}
			.fd-hero-image{margin:0 0 40px}
			.fd-hero-image img{width:100%;border-radius:18px;box-shadow:0 30px 60px -30px rgba(11,61,31,.4)}

			/* PROSE (記事本文) */
			.fd-prose{font-size:16px;line-height:2;color:#1a2a20}
			.fd-prose > *:first-child{margin-top:0}
			.fd-prose p{margin:0 0 1.6em}
			.fd-prose h2{
				font-size:clamp(22px,2.6vw,30px);font-weight:900;line-height:1.4;
				margin:60px 0 20px;padding-left:18px;position:relative;color:var(--ink);
			}
			.fd-prose h2::before{
				content:"";position:absolute;left:0;top:.4em;bottom:.3em;width:6px;
				background:linear-gradient(180deg,var(--lime),var(--green-500));border-radius:3px;
			}
			.fd-prose h3{
				font-size:20px;font-weight:700;line-height:1.5;margin:40px 0 14px;color:var(--green-700);
			}
			.fd-prose h4{font-size:17px;font-weight:700;margin:32px 0 12px}
			.fd-prose a{color:var(--green-700);text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:2px;text-decoration-color:rgba(31,179,90,.4);transition:text-decoration-color .2s}
			.fd-prose a:hover{text-decoration-color:var(--green-700)}
			.fd-prose strong{color:var(--green-900);font-weight:700;background:linear-gradient(transparent 60%, rgba(200,255,60,.5) 60%);padding:0 2px}
			.fd-prose em{font-style:normal;color:var(--green-700)}
			.fd-prose ul,.fd-prose ol{margin:0 0 1.6em;padding-left:1.6em}
			.fd-prose li{margin:0 0 .5em}
			.fd-prose ul li::marker{color:var(--green-500)}
			.fd-prose blockquote{
				margin:30px 0;padding:20px 24px;border-left:4px solid var(--lime);
				background:rgba(200,255,60,.08);border-radius:0 12px 12px 0;
				font-style:normal;color:#2a3a30;
			}
			.fd-prose blockquote p:last-child{margin-bottom:0}
			.fd-prose code{background:rgba(11,61,31,.08);color:var(--green-900);padding:2px 6px;border-radius:4px;font-size:.92em;font-family:ui-monospace,Menlo,Consolas,monospace}
			.fd-prose pre{background:#06140b;color:#e6f3ea;padding:18px 20px;border-radius:12px;overflow-x:auto;margin:24px 0;line-height:1.7}
			.fd-prose pre code{background:transparent;color:inherit;padding:0}
			.fd-prose img{
				width:100%;border-radius:14px;margin:30px 0;
				box-shadow:0 24px 48px -28px rgba(11,61,31,.45);
			}
			.fd-prose hr{border:none;height:1px;background:linear-gradient(90deg,transparent,rgba(11,61,31,.2),transparent);margin:40px 0}
			.fd-prose table{width:100%;border-collapse:collapse;margin:24px 0;font-size:14px}
			.fd-prose th,.fd-prose td{padding:10px 12px;border-bottom:1px solid var(--line);text-align:left}
			.fd-prose th{background:rgba(11,61,31,.05);font-weight:700;color:var(--green-900)}

			/* 記事内に埋め込まれた楽天アフィリエイト等のテーブル装飾はそのまま生かす */
			.fd-prose table[border="0"]{border:none}
			.fd-prose table[border="0"] th,.fd-prose table[border="0"] td{border:none;background:transparent;padding:0}

			/* 記事末ナビ */
			.fd-postNav{display:flex;justify-content:space-between;gap:16px;margin-top:80px;padding-top:40px;border-top:1px solid var(--line);flex-wrap:wrap}
			.fd-btn{display:inline-flex;align-items:center;gap:10px;background:var(--lime);color:var(--ink);font-weight:700;letter-spacing:.15em;padding:14px 22px;border-radius:999px;font-size:13px;transition:transform .2s}
			.fd-btn:hover{transform:translateY(-2px)}
			.fd-btn-outline{display:inline-flex;align-items:center;gap:10px;border:2px solid var(--ink);color:var(--ink);font-weight:700;letter-spacing:.15em;padding:12px 22px;border-radius:999px;font-size:13px;transition:all .2s}
			.fd-btn-outline:hover{background:var(--ink);color:#fff}

			@media (max-width:720px){
				.fd-postHero{padding:100px 0 50px;min-height:auto}
				.fd-postHeroInner{padding:0 24px}
				.fd-article{padding:60px 20px 80px}
				.fd-prose{font-size:15px;line-height:1.95}
			}
		</style>
	</body>
</html>
