      .fd-pInfo dd{margin:0;font-size:13px;font-weight:700;color:var(--ink)}
      .fd-pNote{margin:0;font-size:12px;line-height:1.7;color:#3a4a40;border-top:1px dashed var(--line);padding-top:10px}
      .fd-pLinks{display:flex;gap:12px;flex-wrap:wrap;border-top:1px dashed var(--line);padding-top:10px}
      .fd-pLinks a{font-family:"Bebas Neue",sans-serif;letter-spacing:.18em;font-size:11px;color:var(--green-700);border-bottom:1px solid var(--green-700);padding-bottom:2px;transition:color .2s,border-color .2s}
      .fd-pLinks a:hover{color:var(--green-500);border-color:var(--green-500)}

      /* SCHEDULE */
      .fd-schedule{background:#06140b;color:#fff;padding:120px 0;position:relative;overflow:hidden}
      .fd-schedule::before{content:"SCHEDULE";position:absolute;left:-30px;bottom:-50px;font-family:"Bebas Neue",sans-serif;font-size:240px;letter-spacing:.05em;color:rgba(200,255,60,.04);line-height:.9;pointer-events:none;animation:fd-floatX 18s ease-in-out infinite alternate}
