---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
// Header はこのページではデザインに専用のものを使うため読み込みません。
// Footer は他ページとの統一感のため、共通のものを使います。
---
<html lang="ja">
  <head>
    <BaseHead
      title="FAIRWAY DIARY ｜ JLPGA 観戦ブログ"
      description="JLPGA 日本女子プロゴルフツアーの現地観戦レポートを、動画と写真でお届けする観戦ブログ。"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+JP:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- ============ NAV ============ -->
    <nav class="fd-nav">
      <div class="fd-brand"><span class="fd-dot"></span>FAIRWAY DIARY</div>
      <ul>
        <li><a href="/">HOME</a></li>
        <li><a href="/blog">REPORT</a></li>
        <li><a href="#players">PLAYERS</a></li>
        <li><a href="#schedule">SCHEDULE</a></li>
        <li><a href="/about">ABOUT</a></li>
        <li><a href="/contact">CONTACT</a></li>
      </ul>
      <a href="#subscribe" class="fd-cta">SUBSCRIBE</a>
    </nav>

    <!-- ============ HERO ============ -->
    <header class="fd-hero">
      <div class="fd-heroLayer1" aria-hidden="true"></div>
      <div class="fd-heroLayer2" aria-hidden="true"></div>

      <div class="fd-heroTicker" aria-hidden="true">
        <div class="fd-heroTickerInner">
          <span>FAIRWAY DIARY</span><span>·</span><span>JLPGA 2026</span><span>·</span><span>ON-SITE REPORT</span><span>·</span><span>FAIRWAY DIARY</span><span>·</span><span>JLPGA 2026</span><span>·</span><span>ON-SITE REPORT</span><span>·</span>
        </div>
      </div>
      <div class="fd-heroTicker2" aria-hidden="true">
        <div class="fd-heroTickerInner">
          <span>BIRDIE</span><span>EAGLE</span><span>ALBATROSS</span><span>ACE</span><span>BIRDIE</span><span>EAGLE</span><span>ALBATROSS</span><span>ACE</span><span>BIRDIE</span><span>EAGLE</span><span>ALBATROSS</span><span>ACE</span>
        </div>
      </div>

      <div class="fd-heroBall" aria-hidden="true"></div>
      <div class="fd-heroScan" aria-hidden="true"></div>

      <div class="fd-heroHUD" aria-hidden="true">
        <div class="row"><span class="live"></span><span>LIVE FROM SHIZUOKA</span></div>
        <div>WIND 4.2 m/s · NE</div>
        <div>TEMP 18°C · CLOUDY</div>
        <div class="bar"></div>
      </div>

      <div class="fd-heroInner">
        <span class="fd-badge"><span class="live"></span>JLPGA TOUR 2026 ON-SITE REPORT</span>
        <h1 class="fd-heroTitle">
          <span class="word1">FAIRWAY</span><br />
          <span class="word2">DIARY.</span>
        </h1>
        <p class="fd-heroSub">
          日本女子プロゴルフツアーの現地から。グリーンの息づかい、ギャラリーの歓声、そしてプレーヤーの一打一打を、動画と写真で切り取る観戦ブログ。
        </p>
        <div class="fd-heroMeta">
          <span>EST. 2026</span>
          <span>SHIZUOKA · JAPAN</span>
          <span>VOL. 014</span>
        </div>
      </div>

      <div class="fd-scrollHint">SCROLL</div>
    </header>

    <!-- ============ MARQUEE ============ -->
    <div class="fd-marquee" aria-hidden="true">
      <div class="fd-marqueeInner">
        <span>NOW PLAYING — YAMAHA LADIES OPEN KATSURAGI<span class="star"></span>FINAL ROUND<span class="star"></span>FAIRWAY DIARY VOL.014<span class="star"></span>SUBSCRIBE FOR ON-SITE NOTES<span class="star"></span>JLPGA 2026 SEASON<span class="star"></span></span>
        <span>NOW PLAYING — YAMAHA LADIES OPEN KATSURAGI<span class="star"></span>FINAL ROUND<span class="star"></span>FAIRWAY DIARY VOL.014<span class="star"></span>SUBSCRIBE FOR ON-SITE NOTES<span class="star"></span>JLPGA 2026 SEASON<span class="star"></span></span>
      </div>
    </div>

    <!-- ============ PLAYERS ============ -->
    <section id="players" class="fd-players">
      <div class="fd-container">
        <div class="fd-titleRow">
          <div>
            <div class="fd-eyebrow">PLAYERS / 注目選手</div>
            <h2 class="fd-sectionTitle">2026シーズン、目が離せない11人。</h2>
            <p class="fd-sectionLead">
              現地で追いかけている、いま観たい選手たち。タイトル争いの常連から、伸び盛りのルーキーまで。
              プロフィールと観戦のポイントをまとめました。
            </p>
          </div>
        </div>

        <div class="fd-playerGrid">
          <!-- 1. 佐久間朱莉 -->
          <article class="fd-pCard">
            <div class="fd-pImg">
              <div class="fd-pBg" style="background:radial-gradient(circle at 30% 30%,#1fb35a 0%,transparent 55%),radial-gradient(circle at 70% 70%,#c8ff3c 0%,transparent 45%),linear-gradient(135deg,#0b3d1f,#04120a);"></div>
              <span class="fd-pNum">01</span>
              <div class="fd-pName"><strong>佐久間 朱莉</strong><span>AKARI SAKUMA</span></div>
            </div>
            <div class="fd-pBody">
              <dl class="fd-pInfo">
                <div><dt>生年月日</dt><dd>2002.12.11</dd></div>
                <div><dt>出身</dt><dd>埼玉県川越市</dd></div>
                <div><dt>所属</dt><dd>大東建託</dd></div>
                <div><dt>2025</dt><dd>年間女王／3勝</dd></div>
              </dl>
              <p class="fd-pNote">
                2025年の年間女王。2026年開幕戦ダイキンオーキッドで連覇＋開幕44ホール連続ノーボギーの新記録を樹立。安定感とショットの精度が抜群。
              </p>
              <div class="fd-pLinks">
                <a href="https://www.lpga.or.jp/members/info/1005446" target="_blank" rel="noopener">JLPGA Profile →</a>
              </div>
            </div>
          </article>

          <!-- 2. 菅楓華 -->
          <article class="fd-pCard">
            <div class="fd-pImg">
              <div class="fd-pBg" style="background:radial-gradient(circle at 70% 20%,#7ce0a1 0%,transparent 55%),radial-gradient(circle at 30% 80%,#11733a 0%,transparent 50%),linear-gradient(160deg,#0b3d1f,#06140b);"></div>
              <span class="fd-pNum">02</span>
              <div class="fd-pName"><strong>菅 楓華</strong><span>FUKA SUGA</span></div>
            </div>
            <div class="fd-pBody">
              <dl class="fd-pInfo">
                <div><dt>生年月日</dt><dd>2005.05.17</dd></div>
                <div><dt>出身</dt><dd>宮崎県宮崎市</dd></div>
                <div><dt>所属</dt><dd>ニトリ</dd></div>
                <div><dt>通算</dt><dd>2勝</dd></div>
              </dl>
              <p class="fd-pNote">
                2025年「ミヤギテレビ杯」で初優勝、2026年は台湾ホンハイ・レディースで2勝目。20歳のニュージェネレーション、長身から繰り出す豪打が武器。
              </p>
              <div class="fd-pLinks">
                <a href="https://www.lpga.or.jp/members/info/1007211" target="_blank" rel="noopener">JLPGA Profile →</a>
              </div>
            </div>
          </article>

          <!-- 3. 吉田鈴 -->
          <article class="fd-pCard">
            <div class="fd-pImg">
              <div class="fd-pBg" style="background:radial-gradient(circle at 50% 30%,#c8ff3c 0%,transparent 45%),radial-gradient(circle at 80% 70%,#1fb35a 0%,transparent 50%),linear-gradient(135deg,#04120a,#11733a);"></div>
              <span class="fd-pNum">03</span>
              <div class="fd-pName"><strong>吉田 鈴</strong><span>RIN YOSHIDA</span></div>
            </div>
            <div class="fd-pBody">
              <dl class="fd-pInfo">
                <div><dt>生年月日</dt><dd>2004.02.21</dd></div>
                <div><dt>出身</dt><dd>千葉県市川市</dd></div>
                <div><dt>所属</dt><dd>大東建託</dd></div>
                <div><dt>身長</dt><dd>153cm</dd></div>
              </dl>
              <p class="fd-pNote">
                4度目の挑戦で2024年プロテスト合格、ルーキー2年目。姉はプロゴルファーの吉田優利。153cmの小柄ながら飛距離もあり、姉妹そろってのツアー帯同が話題。
              </p>
              <div class="fd-pLinks">
                <a href="https://www.lpga.or.jp/members/info/1006650" target="_blank" rel="noopener">JLPGA Profile →</a>
              </div>
            </div>
          </article>

          <!-- 4. 安田祐香 -->
          <article class="fd-pCard">
            <div class="fd-pImg">
              <div class="fd-pBg" style="background:radial-gradient(circle at 25% 75%,#c8ff3c 0%,transparent 40%),radial-gradient(circle at 75% 25%,#11733a 0%,transparent 55%),linear-gradient(135deg,#06140b,#0b3d1f);"></div>
              <span class="fd-pNum">04</span>
              <div class="fd-pName"><strong>安田 祐香</strong><span>YUKA YASUDA</span></div>
            </div>
            <div class="fd-pBody">
              <dl class="fd-pInfo">
                <div><dt>生年月日</dt><dd>2000.12.24</dd></div>
                <div><dt>出身</dt><dd>兵庫県神戸市</dd></div>
                <div><dt>所属</dt><dd>NEC</dd></div>
                <div><dt>身長</dt><dd>163cm</dd></div>
              </dl>
              <p class="fd-pNote">
                2019年のオーガスタ女子アマで日本人として唯一出場し3位タイ。19年の最終プロテストに初挑戦合格。安定したスイングと地元神戸での6月「宮里藍サントリー」要注目。
              </p>
              <div class="fd-pLinks">
                <a href="https://www.lpga.or.jp/members/info/1005435" target="_blank" rel="noopener">JLPGA Profile →</a>
                <a href="https://www.instagram.com/oo_______yuka/" target="_blank" rel="noopener">Instagram →</a>
              </div>
            </div>
          </article>

          <!-- 5. 高橋彩華 -->
          <article class="fd-pCard">
            <div class="fd-pImg">
              <div class="fd-pBg" style="background:radial-gradient(circle at 60% 40%,#7ce0a1 0%,transparent 50%),radial-gradient(circle at 20% 80%,#1fb35a 0%,transparent 45%),linear-gradient(135deg,#0b3d1f,#04120a);"></div>
              <span class="fd-pNum">05</span>
              <div class="fd-pName"><strong>高橋 彩華</strong><span>SAYAKA TAKAHASHI</span></div>
            </div>
            <div class="fd-pBody">
              <dl class="fd-pInfo">
                <div><dt>生年月日</dt><dd>1998.07.24</dd></div>
                <div><dt>出身</dt><dd>新潟県新潟市</dd></div>
                <div><dt>所属</dt><dd>サーフビバレッジ</dd></div>
                <div><dt>通算</dt><dd>2勝</dd></div>
              </dl>
              <p class="fd-pNote">
                2022年「フジサンケイレディス」初V、2025年は地元・新潟で開催される「宮里藍サントリー」で2勝目。豪快なドライバーショットとパッティングのキレに注目。
              </p>
              <div class="fd-pLinks">
                <a href="https://www.lpga.or.jp/members/info/1004190" target="_blank" rel="noopener">JLPGA Profile →</a>
                <a href="https://www.instagram.com/t_sayaka724/" target="_blank" rel="noopener">Instagram →</a>
              </div>
            </div>
          </article>

          <!-- 6. 川﨑春花 -->
          <article class="fd-pCard">
            <div class="fd-pImg">
              <div class="fd-pBg" style="background:radial-gradient(circle at 30% 50%,#1fb35a 0%,transparent 50%),radial-gradient(circle at 70% 80%,#c8ff3c 0%,transparent 40%),linear-gradient(160deg,#04120a,#11733a);"></div>
              <span class="fd-pNum">06</span>
              <div class="fd-pName"><strong>川﨑 春花</strong><span>HARUKA KAWASAKI</span></div>
            </div>
            <div class="fd-pBody">
              <dl class="fd-pInfo">
                <div><dt>生年月日</dt><dd>2003.05.01</dd></div>
                <div><dt>出身</dt><dd>京都府京都市</dd></div>
                <div><dt>所属</dt><dd>村田製作所</dd></div>
                <div><dt>主な戦績</dt><dd>女子プロ選手権V</dd></div>
              </dl>
              <p class="fd-pNote">
                2022年「日本女子プロゴルフ選手権」を史上最年少19歳でメジャー制覇。プレッシャー下での集中力が一級品。チームブリヂストンの一員。
              </p>
              <div class="fd-pLinks">
                <a href="https://www.lpga.or.jp/members/info/1006047" target="_blank" rel="noopener">JLPGA Profile →</a>
                <a href="https://www.instagram.com/haru_1551/" target="_blank" rel="noopener">Instagram →</a>
              </div>
            </div>
          </article>

          <!-- 7. 青木香奈子 -->
          <article class="fd-pCard">
            <div class="fd-pImg">
              <div class="fd-pBg" style="background:radial-gradient(circle at 80% 30%,#7ce0a1 0%,transparent 45%),radial-gradient(circle at 20% 70%,#11733a 0%,transparent 50%),linear-gradient(135deg,#0b3d1f,#06140b);"></div>
              <span class="fd-pNum">07</span>
              <div class="fd-pName"><strong>青木 香奈子</strong><span>KANAKO AOKI</span></div>
            </div>
            <div class="fd-pBody">
              <dl class="fd-pInfo">
                <div><dt>生年月日</dt><dd>2000.04.11</dd></div>
                <div><dt>出身</dt><dd>宮崎県宮崎市</dd></div>
                <div><dt>所属</dt><dd>マイナビ</dd></div>
                <div><dt>身長</dt><dd>166cm</dd></div>
              </dl>
              <p class="fd-pNote">
                6度目の挑戦で2024年プロテスト合格、JLPGA97期生。166cmの長身から放たれる飛距離が魅力。宮崎日大高校出身、菅楓華と同郷の宮崎勢。
              </p>
              <div class="fd-pLinks">
                <a href="https://www.lpga.or.jp/members/info/1006498" target="_blank" rel="noopener">JLPGA Profile →</a>
              </div>
            </div>
          </article>

          <!-- 8. 政田夢乃 -->
          <article class="fd-pCard">
            <div class="fd-pImg">
              <div class="fd-pBg" style="background:radial-gradient(circle at 50% 50%,#1fb35a 0%,transparent 50%),radial-gradient(circle at 80% 20%,#c8ff3c 0%,transparent 35%),linear-gradient(135deg,#04120a,#0b3d1f);"></div>
              <span class="fd-pNum">08</span>
              <div class="fd-pName"><strong>政田 夢乃</strong><span>YUMENO MASADA</span></div>
            </div>
            <div class="fd-pBody">
              <dl class="fd-pInfo">
                <div><dt>生年月日</dt><dd>2000.07.28</dd></div>
                <div><dt>出身</dt><dd>北海道札幌市</dd></div>
                <div><dt>所属</dt><dd>なないろ生命保険</dd></div>
                <div><dt>主な戦績</dt><dd>下部4勝</dd></div>
              </dl>
              <p class="fd-pNote">
                2017年高校選手権王者。下部ツアーで2023年シーズン4勝の実績を引っ提げ、同年プロテスト合格。地元北海道での試合は応援に熱が入る。
              </p>
              <div class="fd-pLinks">
                <a href="https://www.lpga.or.jp/members/info/1003043" target="_blank" rel="noopener">JLPGA Profile →</a>
              </div>
            </div>
          </article>

          <!-- 9. 河本結 -->
          <article class="fd-pCard">
            <div class="fd-pImg">
              <div class="fd-pBg" style="background:radial-gradient(circle at 35% 35%,#c8ff3c 0%,transparent 40%),radial-gradient(circle at 75% 70%,#11733a 0%,transparent 55%),linear-gradient(135deg,#0b3d1f,#04120a);"></div>
              <span class="fd-pNum">09</span>
              <div class="fd-pName"><strong>河本 結</strong><span>YUI KAWAMOTO</span></div>
            </div>
            <div class="fd-pBody">
              <dl class="fd-pInfo">
                <div><dt>生年月日</dt><dd>1998.08.29</dd></div>
                <div><dt>出身</dt><dd>愛媛県松山市</dd></div>
                <div><dt>所属</dt><dd>リコー</dd></div>
                <div><dt>通算</dt><dd>4勝</dd></div>
              </dl>
              <p class="fd-pNote">
                2018年プロテスト9位で一発合格、19年ルーキーイヤーに早くも初優勝。米ツアーも経験し、25年は北海道Meijiカップ＆スタンレーレディスで複数勝、計4勝目。芯の通ったプレースタイルが魅力。
              </p>
              <div class="fd-pLinks">
                <a href="https://www.lpga.or.jp/members/info/1002999" target="_blank" rel="noopener">JLPGA Profile →</a>
                <a href="https://www.instagram.com/kawamotoyui_official/" target="_blank" rel="noopener">Instagram →</a>
              </div>
            </div>
          </article>

          <!-- 10. 稲垣那奈子 -->
          <article class="fd-pCard">
            <div class="fd-pImg">
              <div class="fd-pBg" style="background:radial-gradient(circle at 65% 30%,#7ce0a1 0%,transparent 50%),radial-gradient(circle at 25% 75%,#1fb35a 0%,transparent 45%),linear-gradient(160deg,#06140b,#11733a);"></div>
              <span class="fd-pNum">10</span>
              <div class="fd-pName"><strong>稲垣 那奈子</strong><span>NANAKO INAGAKI</span></div>
            </div>
            <div class="fd-pBody">
              <dl class="fd-pInfo">
                <div><dt>生年月日</dt><dd>2000.08.24</dd></div>
                <div><dt>出身</dt><dd>埼玉県川口市</dd></div>
                <div><dt>所属</dt><dd>ミズノ</dd></div>
                <div><dt>身長</dt><dd>164cm</dd></div>
              </dl>
              <p class="fd-pNote">
                早稲田大学スポーツ科学部出身、JLPGA96期生。2025年「リゾートトラスト レディス」でツアー初優勝、早大女子ゴルファー史上初のツアーV。得意のロングアイアンを軸にした堅実なゴルフ。
              </p>
              <div class="fd-pLinks">
                <a href="https://www.lpga.or.jp/members/info/1005447" target="_blank" rel="noopener">JLPGA Profile →</a>
              </div>
            </div>
          </article>

          <!-- 11. 髙野愛姫 -->
          <article class="fd-pCard">
            <div class="fd-pImg">
              <div class="fd-pBg" style="background:radial-gradient(circle at 25% 30%,#1fb35a 0%,transparent 50%),radial-gradient(circle at 80% 80%,#c8ff3c 0%,transparent 40%),linear-gradient(135deg,#04120a,#0b3d1f);"></div>
              <span class="fd-pNum">11</span>
              <div class="fd-pName"><strong>髙野 愛姫</strong><span>AIHI TAKANO</span></div>
            </div>
            <div class="fd-pBody">
              <dl class="fd-pInfo">
                <div><dt>生年月日</dt><dd>2004.09.14</dd></div>
                <div><dt>出身</dt><dd>東京都北区</dd></div>
                <div><dt>所属</dt><dd>Jトラスト銀行インドネシア</dd></div>
                <div><dt>師事</dt><dd>金愛淑</dd></div>
              </dl>
              <p class="fd-pNote">
                母の勧めで石川遼の活躍に憧れ5歳でゴルフを始めた、JLPGA96期生。2025年「ヨネックスレディス」最終日64で逆転V。攻めの姿勢を崩さない若き挑戦者。
              </p>
              <div class="fd-pLinks">
                <a href="https://www.lpga.or.jp/members/info/1007125" target="_blank" rel="noopener">JLPGA Profile →</a>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ============ SCHEDULE ============ -->
    <section id="schedule" class="fd-schedule">
      <div class="fd-container">
        <div class="fd-titleRow">
          <div>
            <div class="fd-eyebrow" style="color:var(--lime);">SCHEDULE / 観戦予定</div>
            <h2 class="fd-sectionTitle" style="color:#fff;">FAIRWAY DIARYの次の現場。</h2>
            <p class="fd-sectionLead" style="color:#cfe6d7;">
              JLPGAツアー2026、これから現地に向かう予定の試合です。日程は予告なく変更される場合があります。
              最新情報は各大会の公式サイトおよびJLPGA公式サイトをご確認ください。
            </p>
          </div>
          <a class="fd-more" href="https://www.lpga.or.jp/tournament/" target="_blank" rel="noopener" style="color:var(--lime);border-color:var(--lime);">VIEW FULL TOUR</a>
        </div>

        <ol class="fd-schedList">
          <li class="fd-schedItem">
            <div class="fd-schedDate">
              <span class="fd-schedMonth">MAY</span>
              <span class="fd-schedDay">07<small>—10</small></span>
            </div>
            <div class="fd-schedBody">
              <span class="fd-schedTag tag-major">MAJOR</span>
              <h3>ワールドレディスチャンピオンシップ サロンパスカップ</h3>
              <p>茨城ゴルフ俱楽部 西コース（茨城）／賞金総額 1億5,000万円</p>
            </div>
            <div class="fd-schedStatus"><span class="dot dot-next"></span>NEXT</div>
          </li>

          <li class="fd-schedItem">
            <div class="fd-schedDate">
              <span class="fd-schedMonth">MAY</span>
              <span class="fd-schedDay">21<small>—24</small></span>
            </div>
            <div class="fd-schedBody">
              <span class="fd-schedTag">REGULAR</span>
              <h3>中京テレビ・ブリヂストンレディスオープン</h3>
